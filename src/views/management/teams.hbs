{{> management-header}}

<div class="bg-white-color px-5 py-3 text-center">
  <div class="row mx-5 mb-2">

    <div class="d-flex justify-content-between align-items-end mb-1">
      <div class="text-muted m-0">
        Hiển thị tổng số <strong>{{teams.length}}</strong> đội.
      </div>
      <a href="/teams/create">
        <button class="btn btn-success">
          <i class="fas fa-plus"></i>
          <span class="ms-1">Thêm đội</span>
        </button>
      </a>
    </div>

    <div class="table-responsive mt-3">
      <table class="table">
        <thead class="table-light">
          <tr>
            <th scope="col">#</th>
            <th scope="col"></th>
            <th scope="col" class="text-start">Tên đội</th>
            <th scope="col">Trình độ</th>
            <th scope="col">Tên liên hệ</th>
            <th scope="col">Số điện thoại</th>
            <th scope="col">Email</th>
            <th scope="col">Trạng thái</th>
            <th scope="col">Thao tác</th>
          </tr>
        </thead>
        <tbody>

          {{#each teams}}
          <tr>
            <th scope="row">{{sum @index 1}}</th>
            <td>
              <img src="/img/teams/{{this.id}}/logo.png" alt="team-logo" height="40px" width="40px"
                class="rounded-circle">
            </td>
            <td class="text-start">
              <a href="/teams/{{this.id}}">{{this.name}}</a>
            </td>
            <td>{{this.level}}</td>
            <td>{{this.contactName}}</td>
            <td>{{this.contactPhone}}</td>
            <td>{{this.contactEmail}}</td>
            {{#if this.tournamentId}}
            {{#if this.status}}
            <td>
              <a href="/tournament/{{this.tournamentId}}" class="link-success">Đã duyệt</a>
            </td>
            {{else}}
            {{#if this.profile}}
            <td>
              <a href="/tournament/{{this.tournamentId}}" class="link-warning">Chưa duyệt</a>
            </td>
            {{else}}
            <td>
              <a href="/teams/{{this.id}}/edit" class="link-danger">Chưa nộp hồ sơ</a>
            </td>
            {{/if}}
            {{/if}}
            {{else}}
            <td>
              <span class="link-secondary">Chưa đăng ký giải</span>
            </td>
            {{/if}}
            <td>
              <div class="d-flex align-items-center justify-content-center">
                <a href="/teams/{{this.id}}/edit">
                  <button class="btn btn-outline-dark">
                    <i class="fas fa-edit"></i>
                  </button>
                </a>
                <a href="/teams/{{this.id}}/delete" class="btn-delete">
                  <button class="btn btn-outline-danger ms-2 ">
                    <i class="fas fa-trash-alt"></i>
                  </button>
                </a>
                {{#unless this.tournamentId}}
                <select class="form-select form-select-sm ms-2 enroll-tournament-select"
                  data-team-id="{{this.id}}" {{#unless ../hasActiveTournament}}disabled{{/unless}}>
                  <option value="">Chọn giải</option>
                  {{#each ../activeTournaments}}
                  <option value="{{this.id}}">{{this.name}}</option>
                  {{/each}}
                </select>
                <button data-team-id="{{this.id}}" class="btn btn-outline-primary ms-2 btn-enroll" {{#unless
                  ../hasActiveTournament}}disabled{{/unless}}>
                  <i class="fas fa-sign-in-alt"></i>
                </button>
                {{/unless}}
              </div>
            </td>
          </tr>
          {{/each}}


        </tbody>
      </table>
    </div>

  </div>
</div>

<script>
  const btnDelete = document.querySelectorAll('.btn-delete');
  btnDelete.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const confirmDelete = confirm('Bạn có chắc chắn muốn xóa đội bóng này?');
      if (confirmDelete) {
        deleteTeam(btn.getAttribute('href'));
      }
    })
  });

  async function deleteTeam(url) {
    const response = await fetch(url, {
      method: 'DELETE',
    });
    window.location.reload();
  }

  const enrollRows = document.querySelectorAll('tr');
  enrollRows.forEach(row => {
    const btn = row.querySelector('.btn-enroll');
    const select = row.querySelector('.enroll-tournament-select');
    if (!btn || !select) return;

    const syncEnrollButtonState = () => {
      if (select.disabled) {
        btn.disabled = true;
        return;
      }
      btn.disabled = !select.value;
    };
    syncEnrollButtonState();
    select.addEventListener('change', syncEnrollButtonState);

    btn.addEventListener('click', async () => {
      const teamId = btn.getAttribute('data-team-id');
      const tournamentId = Number.parseInt(select.value, 10);
      if (!Number.isInteger(tournamentId)) {
        alert('Vui lòng chọn giải đấu để đăng ký.');
        return;
      }

      const response = await fetch(`/teams/${teamId}/enroll-tournament`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ tournamentId }),
      });
      const result = await response.json();
      if (result.status === 'success') {
        window.location.reload();
        return;
      }
      alert(result.msg || 'Không thể đăng ký đội vào giải đã chọn.');
    });
  });
</script>
